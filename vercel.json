{
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/.next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "API endpoint URL (e.g., https://intertalk-api.up.railway.app/api)"
    }
  },
  "rewrites": [
    {
      "source": "/:path((?!api).*)",
      "destination": "/:path"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
